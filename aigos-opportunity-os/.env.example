# =====================================================================
# AI.GOS Opportunity OS - Environment Variables
# ---------------------------------------------------------------------
# Copy this file to ".env.local" and fill in the values.
# The app runs FULLY in demo mode without any of these values.
# Fill them in only when you are ready for Phase 2 (real Google APIs).
# =====================================================================

# --- Demo mode ---------------------------------------------------------
# "true"  => app uses local mock data, no Google calls (recommended start)
# "false" => app tries to use the real Google APIs (requires the keys below)
NEXT_PUBLIC_DEMO_MODE=true

# --- Google OAuth 2.0 --------------------------------------------------
# Create these in Google Cloud Console -> APIs & Services -> Credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- Google Sheets -----------------------------------------------------
# The ID of the spreadsheet used as the database.
# (The long string in the middle of the spreadsheet URL.)
GOOGLE_SHEETS_SPREADSHEET_ID=

# --- AI providers (Phase 2, optional) ----------------------------------
# Only one is needed. Leave blank to keep using the built-in mock AI.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Security ----------------------------------------------------------
# Random secrets. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
ENCRYPTION_KEY=

# --- App ---------------------------------------------------------------
APP_BASE_URL=http://localhost:3000
