# =============================================================
# SHELLY OG — קובץ דוגמה למשתני סביבה
# העתיקי את הקובץ הזה ל-.env.local ומלאי את המפתחות האמיתיים.
# כל עוד המפתחות ריקים, האפליקציה רצה במצב Mock מלא ובטוח.
# =============================================================

# --- מצב הרצה -------------------------------------------------
# mock  = נתוני דמו + AI מדומה (ברירת מחדל, לא דורש מפתחות)
# live  = שימוש בחיבורים אמיתיים (דורש את כל המפתחות למטה)
SHELLY_DATA_MODE=mock

# --- ספק ה-AI -------------------------------------------------
# אם המפתח ריק — נעשה שימוש במנוע ה-AI המדומה (lib/ai/mock-ai.ts).
# נתמך: anthropic (Claude) או openai. ראו lib/ai/index.ts.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Google OAuth (Gmail / Drive / Docs / Sheets / Calendar) --
# צרי פרויקט ב-Google Cloud Console, הפעילי את ה-APIs הרלוונטיים,
# וצרי OAuth Client (Web). ראו README — "חיבור Google אמיתי".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# Refresh token שמתקבל אחרי הסכמת המשתמשת ב-OAuth.
GOOGLE_REFRESH_TOKEN=

# היקפי הרשאה (scopes) — מחוברים ב-lib/google/connectors.
# gmail.readonly, drive.readonly, documents.readonly,
# spreadsheets, calendar.readonly

# --- כללי -----------------------------------------------------
NEXT_PUBLIC_APP_NAME=SHELLY OG
